PORT=

# AWS S3 Configuration (Required for Video Streaming)
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=your_aws_access_key
AWS_SECRET_ACCESS_KEY=your_aws_secret_key
AWS_S3_BUCKET=your-s3-bucket-name

# Optional: CDN URL if using CloudFront for improved performance
AWS_CLOUDFRONT_URL=https://d123456.cloudfront.net

# Streaming Configuration - DO NOT MODIFY unless you know what you're doing
# These settings control buffering behavior for smooth playback
CHUNK_SIZE=262144
MAX_CONCURRENT_STREAMS=3
SOCKET_TIMEOUT=60000